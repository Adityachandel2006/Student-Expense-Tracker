<!DOCTYPE html>
<html>
<head>

<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Student Expense Tracker</title>
<link rel="stylesheet" href="/css/style.css">
<link rel="icon" type="image/svg+xml" href="/images/logo.svg">

</head>

<body>

<header class="navbar">

<a href="/dashboard" class="brand-link">
<img src="/images/logo.svg" alt="Logo" class="logo" style="height:48px; vertical-align:middle; margin-right:14px; box-shadow:0 2px 8px rgba(102,126,234,0.2); border-radius:8px;">
<h2 style="display:inline; vertical-align:middle; font-size:32px; font-weight:800; color:white; letter-spacing:1px;">Expense Tracker</h2>
</a>

<nav style="display: flex; align-items: center; gap: 10px;">
<% if (locals.user && locals.user.profilePic) { %>
  <img src="<%= user.profilePic %>" alt="Profile" style="width: 36px; height: 36px; border-radius: 50%; object-fit: cover; border: 2px solid rgba(255,255,255,0.5);">
<% } %>
<a href="/dashboard">Dashboard</a>
<a href="/profile">Profile</a>
<a href="/report">Report</a>
<a href="/logout">Logout</a>

</nav>

</header>
