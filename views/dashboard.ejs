<%- include("partials/header") %>

<div class="container">
  <div class="dashboard-wrapper">

    
    <div class="main-content">

      
      <div class="welcome-banner">
        <div class="welcome-text">
          <h2>Welcome back! 👋</h2>
          <p>Dashboard is your control center for budget and trends. Use Report for transaction-by-transaction analysis.</p>
        </div>
        <div class="welcome-date-wrap">
          <div class="welcome-date" id="welcomeDate"></div>
          <a href="/report" class="welcome-report-link">Open Transaction Report</a>
        </div>
      </div>

      
      <div class="stats-row">
        <div class="mini-stat">
          <div class="mini-stat-icon" style="background: var(--primary); color: white;">💸</div>
          <div>
            <div class="mini-stat-label">Total Spent</div>
            <div class="mini-stat-value">₹<%= total.toFixed(2) %></div>
          </div>
        </div>
        <div class="mini-stat">
          <div class="mini-stat-icon" style="background: var(--accent); color: white;">📅</div>
          <div>
            <div class="mini-stat-label">This Month</div>
            <div class="mini-stat-value">₹<%= monthTotal.toFixed(2) %></div>
          </div>
        </div>
        <div class="mini-stat">
          <div class="mini-stat-icon" style="background: var(--warning); color: white;">🎯</div>
          <div>
            <div class="mini-stat-label">Budget</div>
            <div class="mini-stat-value">
              <% if (budget !== null) { %>
                ₹<%= budget.toFixed(2) %>
              <% } else { %>
                Not Set
              <% } %>
            </div>
          </div>
        </div>
        <div class="mini-stat remaining-mini" id="remainingMini">
          <div class="mini-stat-icon" id="remainingIcon">💰</div>
          <div>
            <div class="mini-stat-label">Remaining</div>
            <div class="mini-stat-value" id="remainingValueTop">
              <% if (budget !== null) { %>
                ₹<%= (budget - total).toFixed(2) %>
              <% } else { %>
                Set budget
              <% } %>
            </div>
          </div>
        </div>
      </div>

      <div class="budget-progress-card">
        <div class="budget-progress-header">
          <span class="budget-label">Budget Usage</span>
          <span class="budget-pct" id="budgetPct">
            <% if (budget !== null) { %>
              <%= Math.min(Math.round((total / budget) * 100), 100) %>% used
            <% } else { %>
              Budget not set
            <% } %>
          </span>
        </div>
        <div class="progress-track">
          <div class="progress-fill" id="progressFill" style="width:0%"></div>
        </div>
        <div class="budget-progress-footer">
          <span>₹0</span>
          <% if (budget !== null) { %>
            <span>₹<%= budget.toFixed(2) %></span>
          <% } else { %>
            <span>Set budget</span>
          <% } %>
        </div>

        <div class="budget-controls">
          <form action="/dashboard/set-budget" method="POST" class="budget-form">
            <label for="budgetInput">Monthly Budget (₹)</label>
            <div class="budget-form-row">
              <% if (budget !== null) { %>
                <input
                  id="budgetInput"
                  type="number"
                  name="budget"
                  step="0.01"
                  min="0.01"
                  placeholder="Enter your monthly budget"
                  value="<%= budget.toFixed(2) %>"
                  required
                >
              <% } else { %>
                <input
                  id="budgetInput"
                  type="number"
                  name="budget"
                  step="0.01"
                  min="0.01"
                  placeholder="Enter your monthly budget"
                  required
                >
              <% } %>
              <button type="submit" class="save-budget-btn">Save Budget</button>
            </div>
          </form>
          <% if (budget !== null) { %>
            <form action="/dashboard/reset-budget" method="POST">
              <button type="submit" class="reset-budget-btn">Reset Budget</button>
            </form>
          <% } %>
        </div>
      </div>

      
      <div class="categories-section">
        <h3>Filter by Category</h3>
        <div class="categories-grid">
          <button class="category-btn active" onclick="filterCategory('All', this)">🔍 All</button>
          <button class="category-btn" onclick="filterCategory('Food', this)">🍔 Food</button>
          <button class="category-btn" onclick="filterCategory('Transport', this)">🚗 Transport</button>
          <button class="category-btn" onclick="filterCategory('Books', this)">📚 Books</button>
          <button class="category-btn" onclick="filterCategory('Shopping', this)">🛍️ Shopping</button>
          <button class="category-btn" onclick="filterCategory('Other', this)">📌 Other</button>
        </div>
      </div>

      
      <div class="add-expense-card">
        <div class="add-expense-header">
          <h3 id="formTitle">➕ Add New Expense</h3>
          <button class="toggle-form-btn" id="toggleFormBtn" onclick="toggleForm()">Hide Form ▲</button>
        </div>
        <div id="expenseFormWrapper">
          <form id="expenseForm" onsubmit="addExpense(event)">
            <input type="hidden" id="editExpenseId" name="editExpenseId" value="">
            <input type="hidden" id="editExpenseId" name="editExpenseId" value="">
            <div class="form-grid">
              <div class="input-group">
                <label>Expense Title</label>
                <input type="text" name="title" placeholder="e.g. Lunch at canteen" required>
              </div>
              <div class="input-group">
                <label>Amount (₹)</label>
                <input type="number" name="amount" placeholder="0.00" step="0.01" min="0" required>
              </div>
              <div class="input-group">
                <label>Category</label>
                <select name="category" required>
                  <option value="Food">🍔 Food</option>
                  <option value="Transport">🚗 Transport</option>
                  <option value="Books">📚 Books</option>
                  <option value="Shopping">🛍️ Shopping</option>
                  <option value="Other">📌 Other</option>
                </select>
              </div>
              <div class="input-group">
                <label>Date</label>
                <input type="date" name="date" required>
              </div>
            </div>
            <button type="submit" class="submit-btn" id="submitBtn">
              <span id="submitBtnText">+ Add Expense</span>
            </button>
          </form>
        </div>
      </div>

      
      <div class="expenses-section">
        <div class="expenses-header">
          <h3>Your Expenses</h3>
          <span class="expense-count-badge" id="expenseCountBadge">
            <%= expenses.length %> entries
          </span>
        </div>

        <div class="timeline" id="expensesList">
          <%
            const groupedExpenses = {};
            expenses.forEach(e => {
              if (!groupedExpenses[e.date]) groupedExpenses[e.date] = [];
              groupedExpenses[e.date].push(e);
            });
            const sortedDates = Object.keys(groupedExpenses).sort().reverse();
            if (sortedDates.length === 0) {
          %>
            <div class="empty-state">
              <div class="empty-icon">🧾</div>
              <h4>No expenses yet</h4>
              <p>Add your first expense above to get started!</p>
            </div>
          <% } else {
            sortedDates.forEach(date => {
              const dateObj = new Date(date);
              const formattedDate = dateObj.toLocaleDateString('en-GB', {
                year: 'numeric', month: 'long', day: 'numeric'
              });
              const dayTotal = groupedExpenses[date].reduce((s, e) => s + parseFloat(e.amount), 0);
          %>
            <div class="timeline-group">
              <div class="timeline-date">
                <span><%= formattedDate %></span>
                <span class="day-total">₹<%= dayTotal.toFixed(2) %></span>
              </div>
              <% groupedExpenses[date].forEach(exp => { %>
                <div class="expense-item" data-category="<%= exp.category %>">
                  <div class="expense-icon">
                    <% if(exp.category === 'Food') { %>🍔
                    <% } else if(exp.category === 'Transport') { %>🚗
                    <% } else if(exp.category === 'Books') { %>📚
                    <% } else if(exp.category === 'Shopping') { %>🛍️
                    <% } else { %>📌<% } %>
                  </div>
                  <div class="expense-details">
                    <div class="expense-title"><%= exp.title %></div>
                    <span class="expense-category cat-<%= exp.category.toLowerCase() %>"><%= exp.category %></span>
                  </div>
                  <div class="expense-amount">₹<%= parseFloat(exp.amount).toFixed(2) %></div>
                                    <div class="expense-actions" style="display: flex; gap: 8px;">
                    <button type="button" class="edit-btn" title="Edit expense" 
                      data-id="<%= exp.id %>"
                      data-title="<%= exp.title.replace(/"/g, '&quot;') %>"
                      data-amount="<%= exp.amount %>"
                      data-category="<%= exp.category %>"
                      data-date="<%= exp.date ? new Date(exp.date).toISOString().split('T')[0] : '' %>"
                      onclick="openEditMode(this)"
                      style="background: none; border: none; font-size: 1.2rem; cursor: pointer; transition: transform 0.2s;">✏️</button>
                    <form action="/delete/<%= exp.id %>" method="POST" onsubmit="return confirmDelete(event)">
                      <button type="submit" class="delete" title="Delete expense">🗑️</button>
                    </form>
                  </div>
                </div>
              <% }); %>
            </div>
          <% }); } %>
        </div>
      </div>

      
      <div class="charts-section">
        <div class="chart-card">
          <h3>📊 Spending by Category</h3>
          <canvas id="categoryChart"></canvas>
        </div>
        <div class="chart-card">
          <h3>📈 Monthly Trend</h3>
          <canvas id="monthlyChart"></canvas>
        </div>
      </div>

    </div>

    
    <div class="right-panel">

      
      <div class="card stat-highlight">
        <h3>💸 Total Spent</h3>
        <p>₹ <span id="totalAmount"><%= total.toFixed(2) %></span></p>
      </div>

      
      <div class="card">
        <h3>📅 This Month</h3>
        <p>₹ <span id="monthAmount"><%= monthTotal.toFixed(2) %></span></p>
      </div>

      
      <div class="card">
        <h3>🎯 Budget</h3>
        <% if (budget !== null) { %>
          <p><span id="budgetAmount">₹ <%= budget.toFixed(2) %></span></p>
        <% } else { %>
          <p><span id="budgetAmount">Not Set</span></p>
        <% } %>
      </div>

      <div class="card" id="remainingCard">
        <h3>💰 Remaining</h3>
        <% if (budget !== null) { %>
          <p id="remainingAmount">₹ <%= (budget - total).toFixed(2) %></p>
        <% } else { %>
          <p id="remainingAmount">Set your budget</p>
        <% } %>
      </div>

      
      <div class="insights-card">
        <h3>⚡ Quick Insights</h3>
        <div class="insight-list" id="insightList">
          
        </div>
      </div>

      
      <div class="top-category-card" id="topCategoryCard">
        <h3>🏆 Top Category</h3>
        <div id="topCategoryContent">—</div>
      </div>

    </div>

  </div>
</div>


<div id="expensesDataContainer" style="display:none;"><%= JSON.stringify(expenses) %></div>
<div id="totalDataContainer" style="display:none;"><%= total %></div>
<% if (budget !== null) { %>
  <div id="budgetDataContainer" style="display:none;"><%= budget %></div>
<% } else { %>
  <div id="budgetDataContainer" style="display:none;"></div>
<% } %>


<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
  const expensesDataEl = document.getElementById('expensesDataContainer');
  const totalDataEl = document.getElementById('totalDataContainer');
  const budgetDataEl = document.getElementById('budgetDataContainer');
  const expensesData = JSON.parse(expensesDataEl ? expensesDataEl.textContent : '[]');
  const totalVal = totalDataEl ? (parseFloat(totalDataEl.textContent) || 0) : 0;
  const rawBudget = budgetDataEl && budgetDataEl.textContent ? budgetDataEl.textContent.trim() : '';
  const budgetVal = rawBudget ? parseFloat(rawBudget) : null;
  const hasBudget = Number.isFinite(budgetVal) && budgetVal > 0;

  const welcomeDateEl = document.getElementById('welcomeDate');
  if (welcomeDateEl) welcomeDateEl.textContent = new Date().toLocaleDateString('en-IN', {
    weekday: 'long', year: 'numeric', month: 'long', day: 'numeric'
  });

  const dateInput = document.querySelector('input[type="date"]');
  if (dateInput) dateInput.valueAsDate = new Date();

  const remaining = hasBudget ? budgetVal - totalVal : null;
  const remainingCard = document.getElementById('remainingCard');
  const remainingMini = document.getElementById('remainingMini');

  function styleRemaining(el, value) {
    if (value < 0) {
      el.style.background = '#fee2e2';
      el.style.borderColor = '#fca5a5';
    } else if (value < budgetVal * 0.2) {
      el.style.background = '#fef3c7';
      el.style.borderColor = '#fcd34d';
    } else {
      el.style.background = '#dcfce7';
      el.style.borderColor = '#86efac';
    }
  }

  if (hasBudget && remainingCard && remainingMini) {
    styleRemaining(remainingCard, remaining);
    styleRemaining(remainingMini, remaining);
  } else if (remainingCard && remainingMini) {
    remainingCard.style.background = '#f8fafc';
    remainingCard.style.borderColor = '#dee2e6';
    remainingMini.style.background = '#f8fafc';
    remainingMini.style.borderColor = '#dee2e6';
  }

  const remainingAmountEl = document.getElementById('remainingAmount');
  if (!remainingAmountEl) {
  } else if (!hasBudget) {
    remainingAmountEl.style.color = '#4f46e5';
    const remainingIconEl = document.getElementById('remainingIcon');
    if (remainingIconEl) remainingIconEl.textContent = '🎯';
  } else if (remaining < 0) {
    remainingAmountEl.style.color = '#dc2626';
    const remainingIconEl = document.getElementById('remainingIcon');
    if (remainingIconEl) remainingIconEl.textContent = '🚨';
  } else if (remaining < budgetVal * 0.2) {
    remainingAmountEl.style.color = '#d97706';
    const remainingIconEl = document.getElementById('remainingIcon');
    if (remainingIconEl) remainingIconEl.textContent = '⚠️';
  } else {
    remainingAmountEl.style.color = '#16a34a';
    const remainingIconEl = document.getElementById('remainingIcon');
    if (remainingIconEl) remainingIconEl.textContent = '✅';
  }

  const pct = hasBudget ? (totalVal / budgetVal) * 100 : 0;
  const fill = document.getElementById('progressFill');
  if (!fill) {
  } else if (!hasBudget) {
    fill.style.width = '0%';
    fill.style.background = 'rgba(255,255,255,0.2)';
  } else if (pct >= 100) {
    fill.style.width = '100%';
    fill.style.background = '#ef4444';
  } else if (pct >= 80) {
    fill.style.width = Math.min(pct, 100) + '%';
    fill.style.background = '#f59e0b';
  } else {
    fill.style.width = Math.max(pct, 4) + '%';
    fill.style.background = 'linear-gradient(90deg, #667eea, #764ba2)';
  }

  function filterCategory(category, btn) {
    document.querySelectorAll('.category-btn').forEach(b => b.classList.remove('active'));
    if (btn) btn.classList.add('active');
    document.querySelectorAll('.expense-item').forEach(item => {
      if (category === 'All' || item.dataset.category === category) {
        item.style.display = 'flex';
        item.style.animation = 'fadeSlideIn 0.3s ease';
      } else {
        item.style.display = 'none';
      }
    });
    document.querySelectorAll('.timeline-group').forEach(group => {
      const visible = [...group.querySelectorAll('.expense-item')].some(i => i.style.display !== 'none');
      group.style.display = visible ? 'block' : 'none';
    });
  }

  
    let currentEditId = null;

  function openEditMode(btn) {
    const id = btn.dataset.id;
    const title = btn.dataset.title;
    const amount = btn.dataset.amount;
    const category = btn.dataset.category;
    const date = btn.dataset.date;

    currentEditId = id;
    document.getElementById('editExpenseId').value = id;
    
    document.querySelector('input[name="title"]').value = title;
    document.querySelector('input[name="amount"]').value = amount;
    document.querySelector('select[name="category"]').value = category;
    document.querySelector('input[name="date"]').value = date;

    document.getElementById('formTitle').textContent = '✏️ Edit Expense';
    document.getElementById('submitBtnText').textContent = 'Update Expense';
    
    const wrapper = document.getElementById('expenseFormWrapper');
    if (window.getComputedStyle(wrapper).display === 'none') {
      toggleForm();
    }
    
    document.querySelector('.add-expense-card').scrollIntoView({ behavior: 'smooth' });
  }

  function toggleForm() {
    const wrapper = document.getElementById('expenseFormWrapper');
    const btn = document.getElementById('toggleFormBtn');
    const isHidden = window.getComputedStyle(wrapper).display === 'none';
    if (isHidden) {
      wrapper.style.display = 'block';
      btn.textContent = 'Hide Form ▲';
    } else {
      wrapper.style.display = 'none';
      btn.textContent = 'Add Expense ▼';
    }
  }

  async function addExpense(event) {
    event.preventDefault();
    const btn = document.getElementById('submitBtn');
    const btnText = document.getElementById('submitBtnText');
    btnText.textContent = currentEditId ? 'Updating...' : 'Adding...';
    btn.disabled = true;
    btn.style.opacity = '0.7';

    const formData = new FormData(document.getElementById('expenseForm'));
    const data = Object.fromEntries(formData);

    try {
      const url = currentEditId ? `/edit-expense/${currentEditId}` : '/add-expense';
      const response = await fetch(url, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams(data)
      });
      if (response.ok) {
        window.location.reload();
      } else {
        alert(currentEditId ? 'Error updating expense. Please try again.' : 'Error adding expense. Please try again.');
        btnText.textContent = currentEditId ? 'Update Expense' : '+ Add Expense';
        btn.disabled = false;
        btn.style.opacity = '1';
      }
    } catch (err) {
      alert('Network error. Please try again.');
      btnText.textContent = currentEditId ? 'Update Expense' : '+ Add Expense';
      btn.disabled = false;
      btn.style.opacity = '1';
    }
  }

  function confirmDelete(event) {
    if (!confirm('Are you sure you want to delete this expense?')) {
      event.preventDefault();
      return false;
    }
    return true;
  }

  const categoryTotals = {};
  expensesData.forEach(exp => {
    const amount = parseFloat(exp.amount);
    if (!Number.isFinite(amount)) return;
    const category = exp.category || 'Other';
    categoryTotals[category] = (categoryTotals[category] || 0) + amount;
  });

  const topCat = Object.entries(categoryTotals).sort((a,b) => b[1]-a[1])[0];
  const catEmojis = { Food:'🍔', Transport:'🚗', Books:'📚', Shopping:'🛍️', Other:'📌' };

  if (topCat) {
    document.getElementById('topCategoryContent').innerHTML = `
      <div class="top-cat-display">
        <span class="top-cat-emoji">${catEmojis[topCat[0]] || '📌'}</span>
        <div>
          <div class="top-cat-name">${topCat[0]}</div>
          <div class="top-cat-amount">₹${topCat[1].toFixed(2)}</div>
        </div>
      </div>`;
  }

  const insightList = document.getElementById('insightList');
  const avgDaily = expensesData.length > 0
    ? (totalVal / Math.max(1, [...new Set(expensesData.map(e => e.date))].length)).toFixed(0)
    : 0;

  const insights = [
    { icon: '📊', label: 'Avg/day', val: `₹${avgDaily}` },
    { icon: '🧾', label: 'Transactions', val: expensesData.length },
    { icon: '📉', label: 'Budget used', val: hasBudget ? `${Math.min(Math.round(pct), 100)}%` : 'N/A' },
    { icon: '🗂️', label: 'Categories', val: Object.keys(categoryTotals).length }
  ];

  insightList.innerHTML = insights.map(i => `
    <div class="insight-item">
      <span class="insight-icon">${i.icon}</span>
      <span class="insight-label">${i.label}</span>
      <span class="insight-val">${i.val}</span>
    </div>`).join('');

  const categoryCanvas = document.getElementById('categoryChart');
  if (window.Chart && categoryCanvas && Object.keys(categoryTotals).length > 0) {
    const categoryCtx = categoryCanvas.getContext('2d');
    new window.Chart(categoryCtx, {
      type: 'doughnut',
      data: {
        labels: Object.keys(categoryTotals),
        datasets: [{
          data: Object.values(categoryTotals),
          backgroundColor: ['#3b82f6', '#10b981', '#f59e0b', '#ec4899', '#8b5cf6'],
          borderColor: '#fff',
          borderWidth: 3,
          hoverBorderWidth: 0,
          hoverOffset: 8
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        cutout: '65%',
        plugins: {
          legend: { position: 'bottom', labels: { padding: 16, font: { size: 13 } } },
          tooltip: {
            callbacks: {
              label: ctx => ` ₹${ctx.parsed.toFixed(2)}`
            }
          }
        }
      }
    });
  } else if (categoryCanvas) {
    categoryCanvas.parentElement.innerHTML += '<p class="no-data-msg">No data yet</p>';
  }

  const monthlyTotals = {};
  expensesData.forEach(exp => {
    const amount = parseFloat(exp.amount);
    const d = new Date(exp.date);
    if (!Number.isFinite(amount) || Number.isNaN(d.getTime())) return;
    const month = d.toLocaleDateString('en-IN', { month: 'short', year: '2-digit' });
    monthlyTotals[month] = (monthlyTotals[month] || 0) + amount;
  });

  const monthlyCanvas = document.getElementById('monthlyChart');
  if (window.Chart && monthlyCanvas && Object.keys(monthlyTotals).length > 0) {
    const monthlyCtx = monthlyCanvas.getContext('2d');
    new window.Chart(monthlyCtx, {
      type: 'bar',
      data: {
        labels: Object.keys(monthlyTotals),
        datasets: [{
          label: 'Spending (₹)',
          data: Object.values(monthlyTotals),
          backgroundColor: 'rgba(59, 130, 246, 0.4)',
          borderColor: '#3b82f6',
          borderWidth: 2,
          borderRadius: 8,
          borderSkipped: false
        }]
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: { legend: { display: false } },
        scales: {
          y: {
            beginAtZero: true,
            grid: { color: 'rgba(0,0,0,0.05)' },
            ticks: { callback: v => '₹' + v }
          },
          x: { grid: { display: false } }
        }
      }
    });
  } else if (monthlyCanvas) {
    monthlyCanvas.parentElement.innerHTML += '<p class="no-data-msg">No data yet</p>';
  }
</script>
<%- include("partials/footer") %>
