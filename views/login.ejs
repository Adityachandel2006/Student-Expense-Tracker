<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login - Student Expense Tracker</title>
  <link rel="stylesheet" href="/css/style.css">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <script src="https://accounts.google.com/gsi/client" async defer></script>
  <style>
    .google-btn-wrapper {
      margin-top: 15px;
      display: flex;
      justify-content: center;
    }
    .divider {
      display: flex;
      align-items: center;
      text-align: center;
      margin: 20px 0;
      color: var(--text-muted);
      font-size: 13px;
      font-weight: 700;
      text-transform: uppercase;
    }
    .divider::before, .divider::after {
      content: '';
      flex: 1;
      border-bottom: 1px solid var(--border);
    }
    .divider::before { margin-right: 1em; }
    .divider::after { margin-left: 1em; }
    
    .submit-btn-auth {
      background: var(--gradient);
      color: white;
      border: none;
      padding: 14px;
      border-radius: var(--radius-sm);
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
      width: 100%;
      margin-top: 10px;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .submit-btn-auth:hover {
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(102,126,234,0.35);
    }
  </style>
</head>
<body>

<div class="auth-container">
  <div class="auth-image">
    <img src="/images/img1.jpg" alt="Expense Tracker">
  </div>

  <div class="auth-form-side">
    <div class="auth-form-box">
      <h2>💰 Welcome Back</h2>
      <p class="auth-subtitle">Track your expenses and take control of your finances</p>

      <form id="loginForm">
        <input type="text" name="username" placeholder="👤 Username" required>
        <input type="password" name="password" placeholder="🔐 Password" required>
        <button type="submit" class="submit-btn-auth">Login Now</button>
      </form>

      <div class="divider">OR</div>

      <div class="google-btn-wrapper">
        <div id="g_id_onload"
             data-client_id="<%= googleClientId %>"
             data-context="signin"
             data-ux_mode="popup"
             data-callback="handleGoogleLogin"
             data-auto_prompt="false">
        </div>
        <div class="g_id_signin"
             data-type="standard"
             data-shape="rectangular"
             data-theme="outline"
             data-text="signin_with"
             data-size="large"
             data-logo_alignment="left">
        </div>
      </div>

      <div class="auth-footer-text" style="margin-top: 25px;">
        <p>Don't have an account?</p>
        <a href="/register">Create one now</a>
      </div>
    </div>
  </div>
</div>

<script>
  document.getElementById('loginForm').addEventListener('submit', async (e) => {
    e.preventDefault();

    const username = document.querySelector('input[name="username"]').value;
    const password = document.querySelector('input[name="password"]').value;

    try {
      const response = await fetch('/login', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ username, password })
      });

      const data = await response.json();

      if (data.success) {
        window.location.href = '/dashboard';
      } else {
        alert(data.error || 'Login failed');
      }
    } catch (err) {
      alert("Error logging in");
    }
  });

  async function handleGoogleLogin(response) {
    try {
      const res = await fetch('/auth/google', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json'
        },
        body: JSON.stringify({ token: response.credential })
      });
      
      const data = await res.json();
      
      if (data.success) {
        window.location.href = '/dashboard';
      } else {
        alert(data.error || 'Google login failed');
      }
    } catch (err) {
      alert("Error with Google Login");
    }
  }
</script>

</body>
</html>
